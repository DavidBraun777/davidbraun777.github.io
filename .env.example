# Email configuration (Resend)
# Get your API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Server-only recipient for contact form notifications
CONTACT_NOTIFICATION_EMAIL=you@example.com

# Verified sender used by the website contact form
CONTACT_FROM_EMAIL=contact@dbraun.io
CONTACT_FROM_NAME=dbraun.io Contact

# Optional: Calendly event link for direct scheduling in the contact section
CAL_LINK=https://calendly.com/your-handle/intro-call

# Optional: Google Tag Manager
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
